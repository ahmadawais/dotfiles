# ── Identity ──────────────────────────────────────────────────────────────────
[user]
	name = Ahmad Awais
	email = me@AhmadAwais.com
	signingkey = E73BD42BA2C6BF7F

# ── Core ──────────────────────────────────────────────────────────────────────
[core]
	excludesfile = ~/.gitignore
	editor = code --wait
	hooksPath = ~/.githooks

[init]
	defaultBranch = main

# ── Commit & Signing ──────────────────────────────────────────────────────────
[commit]
	gpgsign = true

[gpg]
	program = gpg

# ── Push & Pull ───────────────────────────────────────────────────────────────
[push]
	# https://stackoverflow.com/a/22933955/950111 — git push -u
	default = current
	# No more -u flag needed on first push (git 2.37+).
	autoSetupRemote = true

[fetch]
	# Auto-delete stale remote tracking branches on fetch.
	prune = true

[pull]
	# Since git 2.27 — https://stackoverflow.com/q/62653114/950111
	ff = only

# ── Diff & Merge ──────────────────────────────────────────────────────────────
[rerere]
	# Remember conflict resolutions and reuse them automatically.
	enabled = true

[branch]
	# Show most recently used branches first.
	sort = -committerdate

[merge]
	# Show original code in conflict markers.
	conflictstyle = zdiff3
	tool = code

[diff]
	# Highlight moved code separately from added/removed lines.
	colorMoved = zebra
	tool = default-difftool

[difftool "default-difftool"]
	cmd = code --wait --diff $LOCAL $REMOTE

# ── Log & Colors ──────────────────────────────────────────────────────────────
[log]
	date = relative

[color]
	ui = auto

[color "branch"]
	current = yellow reverse
	local = yellow
	remote = green

[color "diff"]
	meta = yellow bold
	frag = magenta bold
	old = red bold
	new = green bold

[color "status"]
	added = yellow
	changed = green
	untracked = cyan

# ── Credentials & Help ────────────────────────────────────────────────────────
[credential]
	helper = osxkeychain

[help]
	# Automatically correct and execute mistyped commands.
	autocorrect = 1

# ── Filters ───────────────────────────────────────────────────────────────────
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[filter "media"]
	clean = git media clean %f
	smudge = git media smudge %f
	required = true

# ── URL Shortcuts ─────────────────────────────────────────────────────────────
[url "git@github.com:"]
	insteadOf = "gh:"
	pushInsteadOf = "github:"
	pushInsteadOf = "git://github.com/"

[url "git://github.com/"]
	insteadOf = "github:"

[url "git@gist.github.com:"]
	insteadOf = "gst:"
	pushInsteadOf = "gist:"
	pushInsteadOf = "git://gist.github.com/"

[url "git://gist.github.com/"]
	insteadOf = "gist:"

# ── Aliases ───────────────────────────────────────────────────────────────────
[alias]
	# ── Emoji-Log ─────────────────────────────────────────────────────────────
	# Git Commit, Add all and Push — in one step.
	cap = "!f() { git add .; git commit -m \"$@\"; git push; }; f"
	new = "!f() { git cap \"new: $@\"; }; f"
	imp = "!f() { git cap \"improve: $@\"; }; f"
	fix = "!f() { git cap \"fix: $@\"; }; f"
	rlz = "!f() { git cap \"release: $@\"; }; f"
	doc = "!f() { git cap \"doc: $@\"; }; f"
	tst = "!f() { git cap \"test: $@\"; }; f"
	reft = "!f() { git cap \"refactor: $@\"; }; f"

	# ── Basic Shortcuts ────────────────────────────────────────────────────────
	st = status
	ci = commit
	cm = commit -m
	ca = commit --amend
	amend = commit --amend
	co = checkout
	br = branch
	cl = clone
	clr = clone --recursive

	# ── Branch Management ──────────────────────────────────────────────────────
	# Switch to a branch, creating it if necessary.
	go = "!f() { git checkout -b \"$1\" 2> /dev/null || git checkout \"$1\"; }; f"
	# Interactive rebase with the given number of latest commits.
	reb = "!r() { git rebase -i HEAD~$1; }; r"
	# Remove branches already merged with main (skips protected branches).
	dm = "!git branch --merged | grep -v '\\*\\|main\\|master\\|develop\\|staging\\|production\\|gh-pages\\|release' | xargs -n 1 git branch -d"
	# Remove the old tag and re-tag the latest commit.
	retag = "!r() { git tag -d $1 && git push origin :refs/tags/$1 && git tag $1; }; r"

	# ── Log & History ──────────────────────────────────────────────────────────
	hist = log --pretty=format:"%h %ad | %s%d [%an]" --graph --date=short
	changelog = "!_() { t=$(git describe --abbrev=0 --tags); git log ${t}..HEAD --no-merges --pretty=format:'* %s'; }; _"
	le = log --oneline --decorate
	ll = log --pretty=format:"%C(yellow)%h%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate --numstat
	ls1 = log --pretty=format:"%C(yellow)%h%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate
	lds = log --pretty=format:"%C(yellow)%h\\ %C(green)%ad%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate --date=short --graph
	ls = log --pretty=format:"%C(green)%h\\ %C(yellow)[%ad]%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate --date=relative
	lnc = log --pretty=format:"%h\\ %s\\ [%cn]"
	lg1 = log --graph --abbrev-commit --decorate --date=relative --format=format:'%C(red)%h%C(reset) —— %C(bold blue)%an%C(reset): %C(white)%s%C(reset) %C(dim white)  %C(bold green)(%ar)%C(reset) %C(bold yellow)%d%C(reset)' --all
	lg2 = log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold cyan)%aD%C(reset) %C(bold green)(%ar)%C(reset)%C(bold yellow)%d%C(reset)%n''          %C(white)%s%C(reset) %C(dim white)- %an%C(reset)' --all
	lg3 = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --
	lg = log --pretty=format:'%C(yellow)%h%C(reset)  %C(white)%s%C(reset)  %C(dim white)%an%C(reset)  %C(bold green)%ar%C(reset)%C(bold yellow)%d%C(reset)' --abbrev-commit

	# ── Diff & Inspection ─────────────────────────────────────────────────────
	type = cat-file -t
	dump = cat-file -p
	# Show the diff between the latest commit and the current state.
	d = !"git diff-index --quiet HEAD -- || clear; git diff --patch-with-stat"
	# List modified files in last commit.
	dl = "!git ll -1"
	# Diff last commit.
	dlc = diff --cached HEAD^

	# ── Remotes & Tags ────────────────────────────────────────────────────────
	tags = tag -l
	branches = !legit branches
	remotes = remote -v
	# List remotes.
	rem = "!git config -l | grep remote.*url | tail -n +2"

	# ── Collaboration ─────────────────────────────────────────────────────────
	# Credit an author on the latest commit.
	credit = "!f() { git commit --amend --author \"$1 <$2>\" -C HEAD; }; f"
	# List contributors with number of commits.
	contributors = shortlog --summary --numbered
	# Pull in remote changes for the current repository and all its submodules.
	pl = !"git pull; git submodule foreach git pull origin main"

	# ── Legit Integration ─────────────────────────────────────────────────────
	publish = !legit publish
	unpublish = !legit unpublish
	sync = !legit sync
	switch = !legit switch
	resync = !legit resync
	undo = !legit undo

	# ── Meta ──────────────────────────────────────────────────────────────────
	# List all aliases.
	la = "!git config -l | grep alias | cut -c 7-"
